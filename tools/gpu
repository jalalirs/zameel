#!/bin/bash
# Run commands on the GPU machine via SSH.
# Usage:
#   ./tools/gpu "docker ps"               # non-interactive
#   ./tools/gpu -s "sudo something"       # interactive (for sudo)
#   ./tools/gpu                           # interactive shell

GPU_HOST="jalalirs@100.76.65.1"

if [ $# -eq 0 ]; then
    LC_ALL=C LANG=C ssh -t "$GPU_HOST" "export LC_ALL=C LANG=C; bash"
elif [ "$1" = "-s" ]; then
    shift
    LC_ALL=C LANG=C ssh -t "$GPU_HOST" "export LC_ALL=C LANG=C; $*"
else
    LC_ALL=C LANG=C ssh "$GPU_HOST" "export LC_ALL=C LANG=C; $*"
fi
